{
  "name": "autofolio-backend",
  "version": "1.0.0",
  "description": "AutoFolio Vehicle Management Backend",
  "type": "commonjs",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "db:setup": "npm run db:reset && npm run prisma:seed"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/axios": "^3.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.0.0",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/serve-static": "^4.0.2",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "archiver": "^7.0.1",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.3.1",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.1.13",
    "resend": "^6.12.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/csv-parse": "^1.1.12",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/pdfkit": "^0.17.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "prisma": "^7.5.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.0"
  }
}
